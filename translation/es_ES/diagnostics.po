msgstr "¡Existe por lo menos un registro NAPTR con contenido inválido!"

#: core/diag/RADIUSTestsUI.php:263 web/diag/action_realmcheck.php:681
msgid "Checking SRVs:"
msgstr "Comprobando SRVs:"

#. print number of successfully retrieved SRV targets
#: core/diag/RADIUSTestsUI.php:272 web/diag/action_realmcheck.php:691
#, php-format
msgid "%d host names discovered."
msgstr "%d nombres de host resueltos."

#: core/diag/RADIUSTestsUI.php:278 web/diag/action_realmcheck.php:700
